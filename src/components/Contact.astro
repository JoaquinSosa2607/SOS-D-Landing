---
const WA_NUMBER = import.meta.env.PUBLIC_WA_NUMBER;
---

<section id="contact">
  <div class="section-inner">
    <div style="margin-bottom: 56px;">
      <p class="section-label">Escribinos</p>
      <h2 class="section-title">CONTACTO</h2>
      <p class="section-desc">
        ¿Tenés un proyecto? Cotizá sin compromiso.
      </p>
    </div>

    <div class="contact-grid">
      <!-- Info -->
      <div class="contact-info">
        <a class="whatsapp-btn" href={`https://wa.me/${WA_NUMBER}`} target="_blank" rel="noopener">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Envianos un WhatsApp!
        </a>

        <div class="contact-block">
          <p class="contact-block-label">Teléfono / WhatsApp</p>
          <p class="contact-block-value">+54 9 3564 504433</p>
        </div>
        <div class="contact-block">
          <p class="contact-block-label">Email</p>
          <p class="contact-block-value">
            <a href="mailto:contacto@sos-d.com.ar">contacto@sos-d.com.ar</a>
          </p>
        </div>
        <div class="contact-block">
          <p class="contact-block-label">Dirección</p>
          <p class="contact-block-value">Vélez Sarsfield 950, San Francisco, Córdoba</p>
        </div>
      </div>

      <!-- Form -->
      <form class="contact-form" id="contact-form">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="fname">Nombre</label>
            <input class="form-control" type="text" id="fname" name="nombre" placeholder="Tu nombre" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="fphone">Teléfono</label>
            <input class="form-control" type="tel" id="fphone" name="telefono" placeholder="+54 9 11 ..." />
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" for="femail">Email</label>
          <input class="form-control" type="email" id="femail" name="email" placeholder="tu@email.com" required />
        </div>
        <div class="form-group">
          <label class="form-label" for="fsubject">Asunto</label>
          <input class="form-control" type="text" id="fsubject" name="asunto" placeholder="Ej: Cotización conjuntos de fútbol" />
        </div>
        <div class="form-group">
          <label class="form-label" for="fmsg">Mensaje</label>
          <textarea class="form-control" id="fmsg" name="mensaje" rows="5" placeholder="Contanos qué necesitás, cantidad de unidades, colores, fechas..." required></textarea>
        </div>
        <button class="btn-submit" type="submit" id="submit-btn">Enviar consulta</button>
      </form>
    </div>
  </div>
</section>

<script>
  import { supabase } from '../lib/supabase';

  const form      = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';

    const body = {
      name:    (form.querySelector('#fname')    as HTMLInputElement).value,
      phone:   (form.querySelector('#fphone')   as HTMLInputElement).value,
      email:   (form.querySelector('#femail')   as HTMLInputElement).value,
      subject: (form.querySelector('#fsubject') as HTMLInputElement).value,
      message: (form.querySelector('#fmsg')     as HTMLTextAreaElement).value,
    };

    const { error } = await supabase!.functions.invoke('notify-contact', { body });

    if (error) {
      submitBtn.textContent = 'Error al enviar';
      submitBtn.style.background = 'var(--red)';
      setTimeout(() => {
        submitBtn.textContent = 'Enviar consulta';
        submitBtn.style.background = '';
        submitBtn.disabled = false;
      }, 3000);
      return;
    }

    submitBtn.textContent = '✓ Mensaje enviado';
    submitBtn.style.background = '#25D366';
    form.reset();
    setTimeout(() => {
      submitBtn.textContent = 'Enviar consulta';
      submitBtn.style.background = '';
      submitBtn.disabled = false;
    }, 3000);
  });
</script>

<style>
  #contact { background: var(--white); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .contact-info { display: flex; flex-direction: column; gap: 36px; }

  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 32px;
    background: #25D366;
    color: var(--white);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    border-radius: 2px;
    transition: background 0.2s, transform 0.15s;
    align-self: flex-start;
  }
  .whatsapp-btn:hover { background: #1ebe5d; transform: translateY(-1px); }

  .contact-block { display: flex; flex-direction: column; gap: 6px; }
  .contact-block-label {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .contact-block-value { font-size: 1rem; color: var(--ink); }
  .contact-block-value a { color: var(--blue); }
  .contact-block-value a:hover { text-decoration: underline; }

  /* Form */
  .contact-form { display: flex; flex-direction: column; gap: 20px; }

  .form-group { display: flex; flex-direction: column; gap: 8px; }
  .form-label {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .form-control {
    width: 100%;
    padding: 14px 16px;
    border: 1.5px solid var(--border);
    border-radius: 2px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--ink);
    background: var(--white);
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    resize: none;
  }
  .form-control:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(21, 101, 192, 0.1);
  }
  .form-control::placeholder { color: #BDBDBD; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

  .btn-submit {
    align-self: flex-start;
    padding: 16px 36px;
    background: var(--ink);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 2px;
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-submit:hover:not(:disabled) { background: var(--blue); transform: translateY(-1px); }
  .btn-submit:disabled { opacity: 0.7; cursor: default; }

  .form-note { font-size: 0.78rem; color: var(--muted); line-height: 1.5; }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    .form-row     { grid-template-columns: 1fr; }
  }
</style>
